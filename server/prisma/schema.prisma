generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum TicketCategory {
  GENERAL_QUESTION
  TECHNICAL_QUESTION
  REFUND_REQUEST
}

enum TicketMessageSenderType {
  REQUESTER
  STAFF
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  SSLCOMMERZ
  BKASH
}

model Tenant {
  id           String  @id @default(uuid())
  name         String
  slug         String  @unique
  contactEmail String?
  country      String?
  industry     String?
  isActive     Boolean @default(true)

  plan               Plan               @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionEndsAt DateTime?
  paymentProvider    PaymentProvider    @default(MANUAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  requesters        Requester[]
  tickets           Ticket[]
  knowledgeArticles KnowledgeArticle[]
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  phone    String?

  role Role @default(AGENT)

  department String?
  jobTitle   String?

  isActive           Boolean @default(true)
  mustChangePassword Boolean @default(false)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTickets Ticket[] @relation("AssignedTickets")
  ticketMessages   TicketMessage[] @relation("StaffTicketMessages")

  @@index([tenantId])
}

model Requester {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String
  phone      String?
  company    String?
  department String?
  jobTitle   String?
  country    String?
  city       String?
  address    String?
  isActive   Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
  ticketMessages TicketMessage[] @relation("RequesterTicketMessages")

  @@index([tenantId])
}

model Ticket {
  id          String         @id @default(uuid())
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  category    TicketCategory @default(GENERAL_QUESTION)
  aiSummary   String?
  aiReply     String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  assignedAgentId String?
  assignedAgent   User?   @relation("AssignedTickets", fields: [assignedAgentId], references: [id])

  requesterId String?
  requester   Requester? @relation(fields: [requesterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages TicketMessage[]

  @@index([tenantId])
}

model TicketMessage {
  id String @id @default(cuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  senderType TicketMessageSenderType

  senderUserId String?
  senderUser   User? @relation("StaffTicketMessages", fields: [senderUserId], references: [id])

  senderRequesterId String?
  senderRequester   Requester? @relation("RequesterTicketMessages", fields: [senderRequesterId], references: [id])

  message String

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([senderUserId])
  @@index([senderRequesterId])
}

model KnowledgeArticle {
  id       String  @id @default(uuid())
  title    String
  content  String
  category String
  isActive Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model UserSession {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("user_sessions")
  @@ignore
}
