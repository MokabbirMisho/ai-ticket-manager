generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum TicketCategory {
  GENERAL_QUESTION
  TECHNICAL_QUESTION
  REFUND_REQUEST
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  SSLCOMMERZ
  BKASH
}

model Tenant {
  id           String  @id @default(uuid())
  name         String
  slug         String  @unique
  contactEmail String?
  country      String?
  industry     String?
  isActive     Boolean @default(true)

  plan               Plan               @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionEndsAt DateTime?
  paymentProvider    PaymentProvider    @default(MANUAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  students          Student[]
  tickets           Ticket[]
  knowledgeArticles KnowledgeArticle[]
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  role Role @default(AGENT)

  isActive           Boolean @default(true)
  mustChangePassword Boolean @default(false)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTickets Ticket[] @relation("AssignedTickets")

  @@index([tenantId])
}

model Student {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  isActive Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]

  @@index([tenantId])
}

model Ticket {
  id          String         @id @default(uuid())
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  category    TicketCategory @default(GENERAL_QUESTION)
  aiSummary   String?
  aiReply     String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  assignedAgentId String?
  assignedAgent   User?   @relation("AssignedTickets", fields: [assignedAgentId], references: [id])

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model KnowledgeArticle {
  id       String  @id @default(uuid())
  title    String
  content  String
  category String
  isActive Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model UserSession {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("user_sessions")
  @@ignore
}
